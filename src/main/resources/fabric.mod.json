  "authors": [
    "OmniCore Team"
  ],
  "contact": {
    "homepage": "https://github.com/omnicore/omnicore",
    "sources": "https://github.com/omnicore/omnicore"
  },
  "license": "MIT",
  "icon": "assets/omnicore/icon.png",
  "environment": "client",
  "entrypoints": {
